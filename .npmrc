engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
# New deps land with an exact version in package.json. Prevents a
# later `pnpm install` (lockfile regenerate) from silently pulling a
# minor/patch bump on security-sensitive packages. Pairs with
# `--frozen-lockfile` in CI for end-to-end supply-chain pinning.
save-exact=true
