{
  "name": "@crivacy-fhe/adapter-didit",
  "version": "0.1.0",
  "description": "Didit KYC provider adapter for Crivacy. Session creation, decision fetch, webhook verification, and decision-to-flags mapping for the Didit identity verification vendor.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "biome check src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "typescript": "5.6.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/UfukNode/Crivacy-FHE",
    "directory": "packages/fhe-adapter-didit"
  },
  "keywords": [
    "crivacy",
    "kyc",
    "didit",
    "identity-verification",
    "adapter",
    "webhook"
  ]
}
