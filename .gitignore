archive/legacy/**/*.db-shm
archive/legacy/**/*.log

# Database files
*.db
*.db-wal
*.db-shm

# Temp
tmp
.tmp
*.pid

# TestFirm dev-only harness in-memory user mirror
.test-firm-*.json

# Dev tools (never committed)
apps/web/db-query.mjs

# Seed scripts (contain test passwords / dev fixtures)
apps/web/scripts/seed-*.ts

# User upload binaries (privacy: never tracked)
apps/web/data/uploads/

# Private reference materials
ref-dosyalar/

# One-off integration test fixtures (not production code)
apps/web/scripts/test-*.mjs

# Production TODO tracking (project-internal, not for audit/deploy)
PROD-TODO.md

# Legacy reference materials (docs + legacy Express stack)
archive/

# Dev-only KYC snapshot dumps + race-test harness (never committed)
apps/web/.archive/
apps/web/.race-test/
apps/web/.dev-logs/

# Internal sprint/planning docs (not product documentation)
apps/web/docs/

# DB migrations — schema source of truth is src/lib/db/schema/*.ts;
# migrations are regenerated per-environment via `drizzle-kit generate`.
apps/web/src/lib/db/migrations/

# AI assistant instructions (project-internal, not for production/audit)
CLAUDE.md

# Generated OpenAPI artifacts — regenerated via `pnpm openapi:build`
docs/api/openapi.json
docs/api/openapi.yaml

# Internal planning docs (not product documentation)
fhevm/PLAN.md

# Internal project docs (ADRs, architecture, compliance, ops runbooks, security
# audit). The live product documentation is served from the web app itself
# (apps/web/src/content/docs), so this internal folder is not published.
docs/

# Prior-deployment metrics sidecar (validator host only; not used by the app)
infra/alloy/

# Demo video script + scratch design exports (project-internal)
DEMO-SCRIPT.md
/_nft-dark.svg
/_nft-light.svg
