# Test-FHE-Dapp — standalone relying-firm harness. Copy to .env and fill in.

# This firm's own public origin (redirect_uri + webhook URL derive from it).
NEXT_PUBLIC_APP_URL=http://localhost:3002
# The Crivacy gateway this firm calls (OAuth + REST).
CRIVACY_API_BASE_URL=http://localhost:3001

# OAuth client + API key for a firm registered in Crivacy (dashboard > OAuth clients).
# The redirect_uri http://localhost:3002/callback must be whitelisted on the client.
TEST_FIRM_OAUTH_CLIENT_ID=
TEST_FIRM_OAUTH_CLIENT_SECRET=
TEST_FIRM_API_KEY=
TEST_FIRM_DEFAULT_USER_EMAIL=demo@testfirm.dev
TEST_FIRM_DEFAULT_USER_PASSWORD=demo
# Optional — set after registering a webhook endpoint in Crivacy.
# TEST_FIRM_WEBHOOK_SECRET=

# Sepolia read access for the independent on-chain check.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
FHE_KYC_ADDRESS=

# Local session signing for the harness's own user accounts.
AUTH_JWT_SECRET=
AUTH_TOTP_ENCRYPTION_KEY=
