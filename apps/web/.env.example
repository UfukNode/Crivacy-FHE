# --- Application ---
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Crivacy
NEXT_PUBLIC_APP_URL=http://localhost:3001
PORT=3001

# --- Database ---
# Three connection strings drive the runtime, each bound to a
# different Postgres role (see migration
# 20260425120000_rls_roles_grants.sql for the role grants and
# .claude/RLS-REFACTOR-PLAN.md §6 for the architecture rationale).
# Port 5433 matches the default documented in PLAN.md §15 so the new
# backend never collides with the legacy Crivacy Express service that
# may still own :5432 on shared hosts.
#
# DATABASE_URL — back-compat admin connection string. Required by
# tooling that reads the env directly (drizzle-kit CLI, `db:migrate`,
# `scripts/apply-sql-migrations.ts`, pg-boss workers in
# instrumentation.ts). Bound to the `crivacy` owner role in dev — in
# managed prod databases this MUST point at a role that carries the
# BYPASSRLS attribute, otherwise the migration runner's prelude check
# in Faz 7+ migrations will fail loudly.
DATABASE_URL=postgresql://crivacy:crivacy@127.0.0.1:5433/crivacy

# DATABASE_URL_ADMIN — explicit BYPASSRLS admin pool for the Next.js
# runtime (Cat 34b RLS Faz 4.5). When set, getDatabaseClient()
# prefers this for the admin pool slot (adminRoute, pre-auth lookups,
# in-runtime worker queries that go through `getDatabaseClient().db`)
# and DATABASE_URL is only used by the external tooling above. Bound
# to the dedicated `crivacy_admin` role so the admin pool no longer
# relies on the `crivacy` owner happening to carry BYPASSRLS in
# managed-Postgres environments where DBAs strip the attribute.
#
# DEV: leaving this unset is fine — `crivacy` is a docker superuser
# with implicit BYPASSRLS, so the back-compat fallback to
# DATABASE_URL works identically.
#
# PROD: SET THIS. The runtime keeps working without it (silent
# alias to DATABASE_URL), but the moment the managed DB strips
# BYPASSRLS from the owner role, every adminRoute and worker
# pathway breaks. Faz 7+ migrations include a prelude guard that
# fails loudly in that case, but that catches the bug at deploy
# time — the explicit binding here prevents it from existing at all.
# Rotate the password via docs/runbooks/key-rotation.md (key
# `DATABASE_URL_ADMIN`) and load the value from secrets manager.
DATABASE_URL_ADMIN=postgresql://crivacy_admin:crivacy_admin_dev@127.0.0.1:5433/crivacy

# DATABASE_URL_APP is the NOBYPASSRLS handler pool created in the
# Cat 34b RLS refactor (see .claude/RLS-REFACTOR-PLAN.md §1). Every
# dashboardRoute / apiRoute handler call wraps `SET LOCAL app.firm_id`
# against this pool inside a transaction; RLS policies (Faz 7+) read
# the setting via `current_setting('app.firm_id')` to filter rows.
#
# DEV: the migration in 20260425120000_rls_roles_grants.sql provisions
# the role with the placeholder password below. Safe for local docker
# Postgres only.
#
# PROD: rotate the password via the key-rotation runbook
# (docs/runbooks/key-rotation.md) and load the resulting connection
# string from your secrets manager — NEVER commit the prod value.
# Leaving this unset in prod silently re-aliases the app pool onto the
# admin pool (BYPASSRLS), defeating every RLS policy. Set this in
# every deployment that runs production traffic.
DATABASE_URL_APP=postgresql://crivacy_app:crivacy_app_dev@127.0.0.1:5433/crivacy

# Pool sizing (optional overrides — defaults live in client.ts).
# DATABASE_POOL_MAX=20
# DATABASE_STATEMENT_TIMEOUT_MS=15000
# DATABASE_IDLE_IN_TX_TIMEOUT_MS=60000

# --- Auth / secrets (filled in step 5) ---
# JWT_SECRET=
# COOKIE_SECRET=
# API_KEY_HASH_SECRET=

# --- FHE on-chain layer (Zama FHEVM v0.13, Sepolia) ---
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# FHE_KYC_ADDRESS=0x91f410FfCF51abd0389890968b243bb9A32Eb94B      # CrivacyKYC registry
# FHE_NFT_ADDRESS=0x27A9E3DED8a97cC31F451302Fc069b42A72F602a      # CrivacyKycNFT soulbound pass
# FHE_OPERATOR_PRIVATE_KEY=0x...                                   # Crivacy issuer/gatekeeper wallet
# FHE_RELAYER_API_KEY=                                             # MAINNET ONLY. Testnet uses the public relayer
#                                                                  # (relayer.testnet.zama.org) with NO key — leave blank.
# FHE_NETWORK_LABEL=sepolia
# FHE_CHAIN_ID=11155111

# --- Didit (filled in step 9) ---
# DIDIT_BASE_URL=https://verification.didit.me
# DIDIT_API_KEY=
# DIDIT_WEBHOOK_SECRET=
# DIDIT_KYC_WORKFLOW_ID=2ab9f298-699c-4b2c-9ce9-6246c17c6c25
# DIDIT_ADDRESS_WORKFLOW_ID=72b72ee3-85ad-46d2-8558-1d2ff48b1ffb

# --- KYC reconciler (Sprint 3) ---
# Periodic drift sweep that catches the case where neither Didit's
# webhook (push) nor the SSE pull-fallback landed — a Didit-Approved
# verification that never reached the credential-pipeline. The worker
# scans the audit log + DB on a cron and replays the pipeline through
# the same `enqueueCredentialPipeline` path the webhook would have
# taken. See `.claude/KYC-RECONCILER-WORKER.md` for principles + edge
# cases. All five knobs default to safe values; uncomment to override.
#
# Lookback window in hours. Older drifts are manual-ops territory —
# operators run `pnpm tsx scripts/kyc-reconcile-once.ts <customer-id>`
# for any single drift outside this window.
# KYC_RECONCILER_LOOKBACK_HOURS=168
#
# Hard cap on drift candidates per cycle. Bounds the worst-case Didit
# RPS at the configured throttle: `MAX_PER_CYCLE / (THROTTLE_MS / 1000)`
# requests per cycle.
# KYC_RECONCILER_MAX_PER_CYCLE=100
#
# Min interval between Didit GETs in milliseconds (default 500ms = 2 RPS).
# KYC_RECONCILER_THROTTLE_MS=500
#
# Schedule expression. Defaults to every 15 minutes.
# KYC_RECONCILER_CRON=*/15 * * * *
#
# Kill-switch. Set to `true` to keep the worker from registering at
# all (used during initial roll-out, or to silence a misbehaving
# cycle while debugging).
# KYC_RECONCILER_DISABLE=false

# --- Sprint 7 Phase K — dev-mode worker opt-in ---
# By default, `pnpm dev` (Turbopack) skips the pg-boss worker
# bootstrap so the dev server stays cold-start-fast and emails fall
# back to direct SMTP. Set `RUN_WORKERS_IN_DEV=1` to start every
# worker (credential-pipeline, kyc-reconciler, webhook-delivery,
# email-send, session-cleanup, security-events, idempotency-sweeper,
# ip-abuse-pruner) inside the dev process — useful when reproducing
# a stuck-customer mint or a webhook fan-out issue locally without
# a `next build` round-trip.
# RUN_WORKERS_IN_DEV=0

# --- Sprint 6 IP-abuse signal counter ---
# Per-IP repeat-evader gate. Every face-match cascade or block_toast
# event increments a counter keyed by the salted hash of the captured
# IP; when the counter passes the threshold, the next start-session
# call from that IP is rejected with HTTP 503 BEFORE going to Didit.
# See `lib/fraud/ip-abuse.ts` for the contract.
#
# REQUIRED. High-entropy random string (>= 16 chars). Rotation
# invalidates all existing rows by design — privacy-friendly soft
# reset. No fallback: the helper throws at first request if missing.
# IP_ABUSE_HASH_SECRET=
#
# Threshold (number of strikes within the active window). Default 3.
# IP_ABUSE_THRESHOLD=3
#
# Active window in days. Default 7. The nightly pruner DELETEs rows
# whose `last_seen` is older than this.
# IP_ABUSE_TTL_DAYS=7

# --- Observability (filled in step 18) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
# OTEL_SERVICE_NAME=crivacy-api
# LOG_LEVEL=info
