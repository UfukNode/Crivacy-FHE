{
  "uid": "crivacy-system-overview",
  "title": "System Overview",
  "description": "Host-level CPU, memory, disk, network metrics (node-exporter), container resource usage (cadvisor), and PostgreSQL health (postgres-exporter).",
  "tags": ["crivacy", "system", "infrastructure"],
  "editable": false,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "timezone": "utc",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "instance",
        "type": "query",
        "query": "label_values(node_uname_info{job=\"node-exporter\"}, instance)",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1
      },
      {
        "name": "interval",
        "type": "interval",
        "query": "1m,5m,10m,30m,1h",
        "current": {
          "selected": true,
          "text": "1m",
          "value": "1m"
        },
        "hide": 0,
        "auto": true,
        "auto_count": 30,
        "auto_min": "10s"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage",
      "description": "CPU utilization percentage per mode (user, system, iowait, etc.).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "CPU %",
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{job=\"node-exporter\", instance=~\"$instance\", mode=\"idle\"}[$__rate_interval])))",
          "legendFormat": "total used",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "B",
          "expr": "100 * avg by (instance) (rate(node_cpu_seconds_total{job=\"node-exporter\", instance=~\"$instance\", mode=\"user\"}[$__rate_interval]))",
          "legendFormat": "user",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "C",
          "expr": "100 * avg by (instance) (rate(node_cpu_seconds_total{job=\"node-exporter\", instance=~\"$instance\", mode=\"system\"}[$__rate_interval]))",
          "legendFormat": "system",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "D",
          "expr": "100 * avg by (instance) (rate(node_cpu_seconds_total{job=\"node-exporter\", instance=~\"$instance\", mode=\"iowait\"}[$__rate_interval]))",
          "legendFormat": "iowait",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "description": "Current memory utilization as a percentage of total available RAM.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\", instance=~\"$instance\"} / node_memory_MemTotal_bytes{job=\"node-exporter\", instance=~\"$instance\"}))",
          "legendFormat": "memory used %",
          "editorMode": "code",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 3,
      "title": "Memory Usage Over Time",
      "description": "Memory utilization trend showing used, buffers/cache, and available.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "total" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.stacking", "value": { "group": "A", "mode": "none" } },
              { "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\", instance=~\"$instance\"} - node_memory_MemAvailable_bytes{job=\"node-exporter\", instance=~\"$instance\"} - node_memory_Buffers_bytes{job=\"node-exporter\", instance=~\"$instance\"} - node_memory_Cached_bytes{job=\"node-exporter\", instance=~\"$instance\"}",
          "legendFormat": "used",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "B",
          "expr": "node_memory_Buffers_bytes{job=\"node-exporter\", instance=~\"$instance\"} + node_memory_Cached_bytes{job=\"node-exporter\", instance=~\"$instance\"}",
          "legendFormat": "buffers/cache",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "C",
          "expr": "node_memory_MemAvailable_bytes{job=\"node-exporter\", instance=~\"$instance\"}",
          "legendFormat": "available",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "D",
          "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\", instance=~\"$instance\"}",
          "legendFormat": "total",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 4,
      "title": "Disk Usage",
      "description": "Current disk utilization percentage for the root filesystem.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (node_filesystem_avail_bytes{job=\"node-exporter\", instance=~\"$instance\", mountpoint=\"/\", fstype!=\"tmpfs\"} / node_filesystem_size_bytes{job=\"node-exporter\", instance=~\"$instance\", mountpoint=\"/\", fstype!=\"tmpfs\"} * 100)",
          "legendFormat": "disk used %",
          "editorMode": "code",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 5,
      "title": "Disk Usage Over Time",
      "description": "Filesystem space utilization trend for root and data mounts.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_filesystem_size_bytes{job=\"node-exporter\", instance=~\"$instance\", fstype!~\"tmpfs|overlay\"} - node_filesystem_avail_bytes{job=\"node-exporter\", instance=~\"$instance\", fstype!~\"tmpfs|overlay\"}",
          "legendFormat": "used {{mountpoint}}",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "B",
          "expr": "node_filesystem_size_bytes{job=\"node-exporter\", instance=~\"$instance\", fstype!~\"tmpfs|overlay\"}",
          "legendFormat": "total {{mountpoint}}",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 6,
      "title": "Network I/O",
      "description": "Network receive and transmit throughput for physical interfaces.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": true,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "Bps"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/transmit/" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_network_receive_bytes_total{job=\"node-exporter\", instance=~\"$instance\", device!~\"lo|veth.*|docker.*|br-.*\"}[$__rate_interval])",
          "legendFormat": "receive {{device}}",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "B",
          "expr": "rate(node_network_transmit_bytes_total{job=\"node-exporter\", instance=~\"$instance\", device!~\"lo|veth.*|docker.*|br-.*\"}[$__rate_interval])",
          "legendFormat": "transmit {{device}}",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 7,
      "title": "Container CPU",
      "description": "CPU utilization per Docker container (from cadvisor).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "CPU cores",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\", name!=\"\", name!~\"POD|k8s_.*\"}[$__rate_interval]))",
          "legendFormat": "{{name}}",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 8,
      "title": "Container Memory",
      "description": "Working set memory per Docker container (from cadvisor).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "container_memory_working_set_bytes{job=\"cadvisor\", name!=\"\", name!~\"POD|k8s_.*\"}",
          "legendFormat": "{{name}}",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 9,
      "title": "PostgreSQL Connections",
      "description": "Active, idle, and total database connections by state.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "connections",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "max connections" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (state) (pg_stat_activity_count{job=\"postgres-exporter\"})",
          "legendFormat": "{{state}}",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "B",
          "expr": "pg_settings_max_connections{job=\"postgres-exporter\"}",
          "legendFormat": "max connections",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 10,
      "title": "PostgreSQL Transaction Rate",
      "description": "Committed and rolled-back transactions per second.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "tx/s",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/rollback/" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(pg_stat_database_xact_commit{job=\"postgres-exporter\", datname!=\"\"}[$__rate_interval]))",
          "legendFormat": "commit",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "B",
          "expr": "sum(rate(pg_stat_database_xact_rollback{job=\"postgres-exporter\", datname!=\"\"}[$__rate_interval]))",
          "legendFormat": "rollback",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 11,
      "title": "PostgreSQL Table Sizes",
      "description": "Top tables by total size (data + indexes + TOAST) in the Crivacy database.",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 104857600 },
              { "color": "orange", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true, "inspect": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "schemaname" },
            "properties": [
              { "id": "displayName", "value": "Schema" },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "relname" },
            "properties": [
              { "id": "displayName", "value": "Table" },
              { "id": "custom.width", "value": 220 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Total Size" },
              { "id": "unit", "value": "bytes" },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "gauge" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Total Size" }],
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{ "field": "Value", "desc": true }]
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "topk(20, pg_stat_user_tables_size_bytes{job=\"postgres-exporter\"})",
          "legendFormat": "{{schemaname}}.{{relname}}",
          "editorMode": "code",
          "instant": true,
          "range": false,
          "format": "table"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["crivacy"],
      "targetBlank": true,
      "title": "API Overview",
      "type": "dashboards"
    }
  ]
}
