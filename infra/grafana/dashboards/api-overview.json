{
  "uid": "crivacy-api-overview",
  "title": "Crivacy API Overview",
  "description": "Request rates, latencies, error rates, KYC sessions, rate limiting, webhooks, and audit events for the Crivacy KYC API.",
  "tags": ["crivacy", "api", "kyc"],
  "editable": false,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "timezone": "utc",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "interval",
        "type": "interval",
        "query": "1m,5m,10m,30m,1h",
        "current": {
          "selected": true,
          "text": "1m",
          "value": "1m"
        },
        "hide": 0,
        "auto": true,
        "auto_count": 30,
        "auto_min": "10s"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "description": "HTTP requests per second grouped by method and status code.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method, status_code) (rate(crivacy_http_requests_total{job=\"crivacy-api\"}[$__rate_interval]))",
          "legendFormat": "{{method}} {{status_code}}",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (5xx %)",
      "description": "Percentage of HTTP responses returning 5xx status codes.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(crivacy_http_requests_total{job=\"crivacy-api\", status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(crivacy_http_requests_total{job=\"crivacy-api\"}[$__rate_interval])), 1)",
          "legendFormat": "5xx error rate",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 3,
      "title": "P50 / P95 / P99 Latency",
      "description": "HTTP request duration histogram quantiles (seconds).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "duration",
            "drawStyle": "line",
            "fillOpacity": 0,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(crivacy_http_request_duration_seconds_bucket{job=\"crivacy-api\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(crivacy_http_request_duration_seconds_bucket{job=\"crivacy-api\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "editorMode": "code",
          "range": true,
          "instant": false
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(crivacy_http_request_duration_seconds_bucket{job=\"crivacy-api\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 4,
      "title": "Active KYC Sessions",
      "description": "Number of KYC sessions currently in progress (not yet approved/declined).",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "crivacy_kyc_sessions_active{job=\"crivacy-api\"}",
          "legendFormat": "active sessions",
          "editorMode": "code",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 5,
      "title": "Rate Limit Denials",
      "description": "Rate-limited (HTTP 429) responses per second, split by bucket and quota denials.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "denied/s",
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "bucket" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "quota" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(crivacy_ratelimit_denials_total{job=\"crivacy-api\"}[$__rate_interval]))",
          "legendFormat": "{{kind}}",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 6,
      "title": "Quota Usage (Top 10 Firms)",
      "description": "Monthly quota consumption for the top 10 firms by usage percentage.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true, "inspect": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "firm_id" },
            "properties": [
              { "id": "displayName", "value": "Firm ID" },
              { "id": "custom.width", "value": 280 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Usage %" },
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "gauge" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "tier" },
            "properties": [
              { "id": "displayName", "value": "Tier" },
              { "id": "custom.width", "value": 100 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Usage %" }],
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{ "field": "Value", "desc": true }]
          }
        },
        {
          "id": "limit",
          "options": { "limitField": 10 }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, 100 * crivacy_quota_used{job=\"crivacy-api\"} / clamp_min(crivacy_quota_limit{job=\"crivacy-api\"}, 1))",
          "legendFormat": "{{firm_id}} ({{tier}})",
          "editorMode": "code",
          "instant": true,
          "range": false,
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "title": "Webhook Delivery Success Rate",
      "description": "Percentage of webhook deliveries that succeeded (HTTP 2xx from recipient) over the selected time range.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(crivacy_webhook_deliveries_total{job=\"crivacy-api\", outcome=\"success\"}[$__rate_interval])) / clamp_min(sum(rate(crivacy_webhook_deliveries_total{job=\"crivacy-api\"}[$__rate_interval])), 1e-10)",
          "legendFormat": "success rate",
          "editorMode": "code",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 9,
      "title": "Audit Events Rate",
      "description": "Audit log events per second grouped by action domain (auth, kyc, webhook, admin).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "events/s",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum", "mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (action_domain) (rate(crivacy_audit_events_total{job=\"crivacy-api\"}[$__rate_interval]))",
          "legendFormat": "{{action_domain}}",
          "editorMode": "code",
          "range": true,
          "instant": false
        }
      ]
    },
    {
      "id": 10,
      "title": "API Key Usage (Top 10)",
      "description": "Top 10 API keys by total request count over the selected time range.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true, "inspect": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "api_key_id" },
            "properties": [
              { "id": "displayName", "value": "API Key ID" },
              { "id": "custom.width", "value": 280 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "firm_id" },
            "properties": [
              { "id": "displayName", "value": "Firm" },
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Requests" },
              { "id": "unit", "value": "short" },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "gauge" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Requests" }],
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{ "field": "Value", "desc": true }]
          }
        },
        {
          "id": "limit",
          "options": { "limitField": 10 }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (api_key_id, firm_id) (increase(crivacy_http_requests_total{job=\"crivacy-api\", api_key_id!=\"\"}[$__range])))",
          "legendFormat": "{{api_key_id}}",
          "editorMode": "code",
          "instant": true,
          "range": false,
          "format": "table"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["crivacy"],
      "targetBlank": true,
      "title": "System Overview",
      "type": "dashboards"
    }
  ]
}
