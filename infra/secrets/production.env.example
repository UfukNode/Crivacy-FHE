# Production environment variables for the Crivacy API.
#
# This file is the TEMPLATE. The actual encrypted file is production.env
# (encrypted via sops with age).
#
# To create the encrypted version:
#   1. Copy this file: cp production.env.example production.env
#   2. Fill in real values
#   3. Encrypt: sops --encrypt --in-place production.env
#
# To deploy:
#   sops --decrypt production.env | ssh root@<BACKEND_API_HOST> "cat > /opt/crivacy/api/.env"

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Three roles drive Row-Level Security (see migration 20260425120000):
#   crivacy_admin  BYPASSRLS    -> admin routes, pg-boss workers, migrations
#   crivacy_app    NOBYPASSRLS  -> firm/customer handler pool, RLS-filtered
#
# DATABASE_URL_APP is REQUIRED in production. If it is missing (or equal to
# the admin connection), the app pool silently falls back to the BYPASSRLS
# admin role, RLS is bypassed, and cross-tenant isolation is lost. The app
# now refuses to boot in that case (AUDIT C-2). Rotate the role passwords
# (crivacy_app_dev / crivacy_admin_dev placeholders) before production.
DATABASE_URL_ADMIN=postgresql://crivacy_admin:CHANGE_ME_ADMIN_PASSWORD@127.0.0.1:5433/crivacy?sslmode=disable
DATABASE_URL_APP=postgresql://crivacy_app:CHANGE_ME_APP_PASSWORD@127.0.0.1:5433/crivacy?sslmode=disable
# Back-compat fallback for the admin pool only. DATABASE_URL_ADMIN takes
# precedence; keep this for tooling that still reads DATABASE_URL.
DATABASE_URL=postgresql://crivacy:CHANGE_ME_DB_PASSWORD@127.0.0.1:5433/crivacy?sslmode=disable

# ---------------------------------------------------------------------------
# Auth — JWT
# ---------------------------------------------------------------------------
# REQUIRED: HS256 signing key, at least 32 raw characters.
# Generate: openssl rand -base64 48
AUTH_JWT_SECRET=CHANGE_ME_64_CHAR_BASE64_STRING

# Optional overrides (defaults shown):
# AUTH_JWT_ISSUER=crivacy-api
# AUTH_JWT_FIRM_AUDIENCE=crivacy.firm
# AUTH_JWT_ADMIN_AUDIENCE=crivacy.admin
# AUTH_JWT_CUSTOMER_AUDIENCE=crivacy.customer
# AUTH_JWT_ACCESS_TTL_SECONDS=3600
# AUTH_JWT_REFRESH_TTL_SECONDS=2592000

# ---------------------------------------------------------------------------
# Auth — TOTP encryption
# ---------------------------------------------------------------------------
# REQUIRED: 32-byte AES key for encrypting TOTP secrets at rest.
# Generate: openssl rand -base64 32
AUTH_TOTP_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTE_KEY

# Optional overrides (defaults shown):
# AUTH_TOTP_ENCRYPTION_KEY_VERSION=1
# AUTH_TOTP_ISSUER=Crivacy
# AUTH_TOTP_STEP_SECONDS=30
# AUTH_TOTP_DIGITS=6
# AUTH_TOTP_DRIFT_STEPS=1

# ---------------------------------------------------------------------------
# Auth — API keys & passwords
# ---------------------------------------------------------------------------
# Optional overrides (defaults shown):
# AUTH_API_KEY_BCRYPT_COST=12
# AUTH_API_KEY_GRACE_PERIOD_HOURS=24
# AUTH_PASSWORD_ARGON2_MEMORY_KIB=65536
# AUTH_PASSWORD_ARGON2_ITERATIONS=3
# AUTH_PASSWORD_ARGON2_PARALLELISM=4
# AUTH_PASSWORD_MIN_LENGTH=12

# ---------------------------------------------------------------------------
# Auth — Webhook signing encryption
# ---------------------------------------------------------------------------
# REQUIRED: AES-256 key for encrypting webhook signing secrets at rest.
# Generate: openssl rand -base64 32
AUTH_WEBHOOK_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTE_KEY

# ---------------------------------------------------------------------------
# Customer auth
# ---------------------------------------------------------------------------
# Optional overrides (defaults shown):
# CUSTOMER_MAX_FAILED_ATTEMPTS=5
# CUSTOMER_LOCK_DURATION_MINUTES=30
# CUSTOMER_VERIFICATION_CODE_TTL=600
# CUSTOMER_RESET_CODE_TTL=600
# CUSTOMER_MAX_CODE_ATTEMPTS=5
# CUSTOMER_MAX_CODES_PER_WINDOW=3
# CUSTOMER_CODE_RATE_LIMIT_WINDOW_MINUTES=15
# CUSTOMER_ACCESS_TTL_SECONDS=900
# CUSTOMER_REFRESH_TTL_SECONDS=2592000
# CUSTOMER_REMEMBER_ME_TTL_DAYS=30

# ---------------------------------------------------------------------------
# Google OAuth (optional — leave empty to disable Google sign-in)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.crivacy.io/api/customer/auth/google/callback

# ---------------------------------------------------------------------------
# Turnstile (Cloudflare bot protection)
# ---------------------------------------------------------------------------
TURNSTILE_SECRET_KEY=CHANGE_ME
NEXT_PUBLIC_TURNSTILE_SITE_KEY=CHANGE_ME

# ---------------------------------------------------------------------------
# SMTP (transactional email via nodemailer)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=noreply@crivacy.io
SMTP_PASS=CHANGE_ME_APP_PASSWORD
SMTP_SECURE=true
SMTP_FROM=noreply@crivacy.io
# SMTP_REPLY_TO=support@crivacy.io

# Optional rate-limit overrides (defaults shown):
# EMAIL_MAX_PER_USER_PER_HOUR=5
# EMAIL_MAX_RESENDS_PER_WINDOW=3
# EMAIL_VERIFICATION_TTL_SECONDS=86400
# EMAIL_RESET_TTL_SECONDS=3600

# ---------------------------------------------------------------------------
# FHE (Zama FHEVM on Sepolia)
# ---------------------------------------------------------------------------
FHE_KYC_ADDRESS=CHANGE_ME
FHE_NFT_ADDRESS=CHANGE_ME
FHE_OPERATOR_PRIVATE_KEY=CHANGE_ME
# MAINNET ONLY. Sepolia testnet uses the public relayer (no key).
# FHE_RELAYER_API_KEY=

# ---------------------------------------------------------------------------
# Didit (KYC verification provider)
# ---------------------------------------------------------------------------
DIDIT_API_KEY=CHANGE_ME
DIDIT_WEBHOOK_SECRET=CHANGE_ME_MIN_16_CHARS
DIDIT_KYC_WORKFLOW_ID=2ab9f298-699c-4b2c-9ce9-6246c17c6c25
DIDIT_ADDRESS_WORKFLOW_ID=72b72ee3-85ad-46d2-8558-1d2ff48b1ffb
DIDIT_DEFAULT_CALLBACK_URL=https://api.crivacy.io/api/webhooks/didit

# ---------------------------------------------------------------------------
# Customer credential pipeline
# ---------------------------------------------------------------------------
# The firm_id used for self-service (customer portal) credential storage.
# Must match an existing firm row in the database.
CRIVACY_SELF_SERVICE_FIRM_ID=CHANGE_ME_UUID

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
LOG_LEVEL=info
OTEL_ENABLED=true
OTEL_SERVICE_NAME=crivacy-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
METRICS_ENABLED=true
METRICS_PREFIX=crivacy_

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=3001
HOSTNAME=127.0.0.1
NEXT_PUBLIC_APP_URL=https://api.crivacy.io
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.crivacy.io
NEXT_PUBLIC_DOCS_URL=https://docs.crivacy.io
NEXT_PUBLIC_STATUS_URL=https://status.crivacy.io

# ---------------------------------------------------------------------------
# Build-time (set by CI, not in .env file typically)
# ---------------------------------------------------------------------------
# GIT_SHA=0000000
